# MongoDB connection string for Mongoose
MONGODB_URI=

# NextAuth secret used to sign JWT/session tokens
NEXTAUTH_SECRET=

# Public URL where the app is served (e.g. http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# Authorized admin email for admin API route checks
ADMIN_EMAIL=

# Exactly 32 characters key for AES-256 encryption
ENCRYPTION_KEY=

# Public app name shown in the UI
NEXT_PUBLIC_APP_NAME=FDBK
